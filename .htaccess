# ============================================================
# kps-it.de – Apache .htaccess für Strato Hosting Basic
# ============================================================

AddDefaultCharset UTF-8
Options -Indexes
ServerSignature Off

# ============================================================
# HTTPS + www-Weiterleitung (Strato aktiviert SSL automatisch)
# ============================================================
<IfModule mod_rewrite.c>
    RewriteEngine On

    # HTTP → HTTPS
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

    # ohne www → mit www
    RewriteCond %{HTTPS} on
    RewriteCond %{HTTP_HOST} !^www\. [NC]
    RewriteRule ^(.*)$ https://www.kps-it.de/$1 [R=301,L]

    # data/-Verzeichnis komplett sperren
    RewriteRule ^data/ - [F,L]
</IfModule>

# ============================================================
# PHP-Einstellungen (Strato Hosting Basic – PHP 8.x)
# ============================================================
<IfModule mod_php8.c>
    php_value upload_max_filesize 8M
    php_value post_max_size 8M
    php_value max_execution_time 30
    php_value memory_limit 128M
    php_flag display_errors Off
    php_flag log_errors On
    php_value session.cookie_httponly 1
    php_value session.cookie_samesite Strict
    php_value session.use_strict_mode 1
    php_value session.gc_maxlifetime 3600
</IfModule>
<IfModule mod_php7.c>
    php_value upload_max_filesize 8M
    php_value post_max_size 8M
    php_value max_execution_time 30
    php_value memory_limit 128M
    php_flag display_errors Off
    php_flag log_errors On
    php_value session.cookie_httponly 1
    php_value session.cookie_samesite Strict
</IfModule>

# ============================================================
# SICHERHEITS-HEADER
# ============================================================
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS
    # CSP: Leaflet, Google Fonts, CDN erlauben
    Header always set Content-Security-Policy "default-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://unpkg.com https://cdnjs.cloudflare.com; font-src 'self' https://fonts.gstatic.com; script-src 'self' 'unsafe-inline' https://unpkg.com https://cdnjs.cloudflare.com; img-src 'self' data: https://*.tile.openstreetmap.org https://*.openstreetmap.org https://*.basemaps.cartocdn.com https://*.carto.com blob:; connect-src 'self' https://*.basemaps.cartocdn.com https://*.carto.com; frame-ancestors 'none';"
</IfModule>

# ============================================================
# BROWSER-CACHING (Performance)
# ============================================================
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css                "access plus 1 month"
    ExpiresByType application/javascript  "access plus 1 month"
    ExpiresByType image/png               "access plus 6 months"
    ExpiresByType image/jpeg              "access plus 6 months"
    ExpiresByType image/gif               "access plus 6 months"
    ExpiresByType image/svg+xml           "access plus 6 months"
    ExpiresByType image/webp              "access plus 6 months"
    ExpiresByType image/x-icon            "access plus 1 year"
    ExpiresByType font/woff2              "access plus 1 year"
    ExpiresByType application/font-woff2  "access plus 1 year"
    ExpiresByType text/html               "access plus 1 hour"
    ExpiresByType application/json        "access plus 0 seconds"
</IfModule>

# ============================================================
# GZIP-KOMPRIMIERUNG
# ============================================================
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript
    AddOutputFilterByType DEFLATE application/json application/xml text/xml
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ============================================================
# DATEIZUGRIFF SPERREN
# ============================================================
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

<FilesMatch "\.(log|sql|bak|env|md)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# ============================================================
# MIME-TYPES (PWA Manifest)
# ============================================================
<IfModule mod_mime.c>
    AddType application/manifest+json .webmanifest
    AddType text/javascript .js
    AddType image/webp .webp
</IfModule>

# ============================================================
# FEHLERSEITEN
# ============================================================
ErrorDocument 404 /offline.html
ErrorDocument 403 /offline.html
ErrorDocument 503 /offline.html
