# KPS-IT Beispiel-Konfiguration (keine echten Secrets eintragen)
# Diese Datei ist nur eine Vorlage.
# In Shared Hosting Umgebungen ohne dotenv-Loader bitte stattdessen SetEnv in .htaccess nutzen.

# Datenbankmodus aktivieren: true oder false
KPS_USE_DB=false

# Datenbankverbindung (nur bei KPS_USE_DB=true)
KPS_DB_HOST=localhost
KPS_DB_NAME=kpsit_db
KPS_DB_USER=kpsit_user
KPS_DB_PASS=CHANGE_ME

# Salt fuer anonymisierte Statistik-Hashes
KPS_STATS_SALT=CHANGE_ME_TO_A_LONG_RANDOM_VALUE
